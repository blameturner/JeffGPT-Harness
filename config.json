{
  "models": {},
  "features": {
    "chat": {
      "enabled": true,
      "models": {
        "chat":           { "role": "t1_primary" },
        "chat_summarise": { "role": "exp_rwkv_r", "temperature": 0.1, "max_tokens": 500, "max_input_chars": 16000, "frequency_penalty": 0.2 }
      }
    },
    "code": {
      "enabled": true,
      "models": {
        "code": { "role": "t1_primary" }
      }
    },
    "web_search": {
      "enabled": true,
      "models": {
        "web_search_summarise":       { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 150, "max_input_chars": 3000, "frequency_penalty": 0.2 },
        "web_search_summarise_batch": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 250, "max_input_chars": 4000, "frequency_penalty": 0.2 }
      }
    },
    "rag_lookup": true,
    "tools_framework": {
      "enabled": true,
      "models": {
        "tool_planner": { "role": "t3_tool", "temperature": 0.1, "max_tokens": 200, "max_input_chars": 1000 }
      }
    },
    "search_extraction": {
      "enabled": true,
      "models": {
        "search_extraction": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 350, "max_input_chars": 4000, "frequency_penalty": 0.2 },
        "content_quality":   { "role": "t3_tool",    "temperature": 0.0, "max_tokens": 6,   "max_input_chars": 1500 }
      }
    },
    "intent_classifier": {
      "enabled": true,
      "models": {
        "intent_classifier": { "role": "t3_tool", "temperature": 0.1, "max_tokens": 300, "max_input_chars": 2000 }
      }
    },
    "url_scraper": {
      "enabled": true,
      "max_urls_per_turn": 3,
      "max_links_per_url": 30,
      "scrape_timeout_s": 60
    },
    "models": {
      "http_timeout_s": 3600
    },
    "scraper": {
      "enabled": true,
      "batch_size": 10,
      "summariser_model": "scrape_summariser",
      "classifier_model": "scrape_classifier",
      "dispatch_interval_minutes": 10,
      "max_jobs_per_dispatch": 25,
      "min_run_interval_seconds": 120,
      "rag_collection": "discovery",
      "summary_collection": "discovery_summaries",
      "_comment_models": "scrape_summariser/classifier are for background enrichment queue jobs only. chat/code web search uses features.web_search.models.*. research uses features.research.models.research_search_extraction.",
      "models": {
        "scrape_summariser": { "role": "exp_rwkv_r", "temperature": 0.2, "max_tokens": 500, "max_input_chars": 12000, "frequency_penalty": 0.2 },
        "scrape_classifier": { "role": "t3_tool",    "temperature": 0.1, "max_tokens": 200, "max_input_chars": 8000 }
      }
    },
    "research": {
      "planner_enabled": true,
      "agent_enabled": true,
      "max_queries": 20,
      "max_iterations": 3,
      "planner_retry_attempts": 5,
      "planner_retry_backoff_s": 8,
      "planner_timeout_s": 1800,
      "web_search_per_query_timeout_s": 600,
      "synthesis_timeout_s": 3600,
      "critic_timeout_s": 1800,
      "confidence_threshold": 80,
      "search_extraction_model": "research_search_extraction",
      "models": {
        "research_planner":          { "role": "t1_secondary", "temperature": 0.2, "max_tokens": 4000,  "max_input_chars": 10000 },
        "research_agent":            { "role": "t1_secondary", "temperature": 0.3, "max_tokens": 13000, "max_input_chars": 30000 },
        "research_search_extraction": { "role": "exp_rwkv_r",   "temperature": 0.2, "max_tokens": 500,   "max_input_chars": 12000, "frequency_penalty": 0.2 }
      }
    },
    "planned_search": {
      "enabled": true,
      "successful_scrapes_needed": 10,
      "scrape_timeout_s": 1800,
      "synthesis_timeout_s": 1800,
      "models": {
        "planned_search":        { "role": "t3_tool",      "temperature": 0.1, "max_tokens": 500,  "max_input_chars": 10000 },
        "planned_search_answer": { "role": "t1_secondary", "temperature": 0.3, "max_tokens": 8000, "max_input_chars": 24000 }
      }
    },
    "graph_extract": {
      "enabled": true,
      "models": {
        "relationships": { "role": "t1_secondary", "temperature": 0.1, "max_tokens": 800, "max_input_chars": 8000, "frequency_penalty": 0.3 }
      }
    },
    "pathfinder": {
      "enabled": true,
      "max_depth": 0,
      "max_pages": 500,
      "concurrency": 8,
      "per_host_delay_s": 0.5,
      "robots_cache_ttl_s": 3600,
      "sitemap_limit": 200,
      "recrawl_interval_minutes": 10,
      "batch_size": 5,
      "max_links_per_seed": 100,
      "stale_after_minutes": 60,
      "fallback_to_scrape_targets": true,
      "min_run_interval_seconds": 120
    },
    "discover_agent": {
      "enabled": true,
      "run_interval_minutes": 20,
      "min_run_interval_seconds": 1080,
      "sample_collection": "discovery",
      "sample_chunks": 12,
      "sample_max_chars_per_chunk": 400,
      "queries_per_run": 6,
      "results_per_query": 8,
      "max_roots_per_run": 10,
      "query_model": "tool_planner"
    },
    "scraper_runtime": {
      "_comment": "scraper feature config lives in features.scraper — this key is unused; the scraper handler reads scraper.min_run_interval_seconds",
      "min_run_interval_seconds": 120
    },
    "tool_queue": {
      "startup_grace_seconds": 600,
      "strict_chat_idle_seconds": 600,
      "default_max_attempts": 3,
      "default_retry_backoff_seconds": 5,
      "priority_backoff_seconds": {
        "1": 600,
        "2": 600,
        "3": 600,
        "4": 600,
        "5": 600
      },
      "default_backoff_seconds": 600,
      "job_type_min_idle_seconds": {
        "summarise_page": 300,
        "pathfinder_crawl": 1200,
        "discover_agent_run": 1200
      },
      "job_type_max_attempts": {
        "summarise_page": 3,
        "classify_relevance": 3,
        "scrape_target": 2,
        "pathfinder_crawl": 2,
        "discover_agent_run": 2,
        "research_planner": 2,
        "research_agent": 2,
        "planned_search_execute": 2,
        "planned_search_scrape": 2
      },
      "job_type_additional_idle_seconds": {
        "summarise_page": 0,
        "pathfinder_crawl": 0,
        "discover_agent_run": 0
      }
    }
  }
}
